# ─────────────────────────────────────────────────────────────────────────────
# {{APP_DISPLAY_NAME}} — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values for your target environment
#   3. Build:           npm run build
#   4. Deploy:          pac code push  (see DEPLOYMENT.md)
#
# IMPORTANT: .env is gitignored. Each developer/environment has their own copy.
# Vite substitutes these at BUILD time — changing .env after build has no effect.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend type ──────────────────────────────────────────────────────────────
# Options: sharepoint | dataverse
VITE_BACKEND_TYPE=sharepoint

# ── SharePoint connection (fill if BACKEND_TYPE=sharepoint) ───────────────────
# Full URL of the SharePoint site (no trailing slash)
# Example DEV:  https://yourorg.sharepoint.com/sites/Apps-Dev
# Example TEST: https://yourorg.sharepoint.com/sites/Apps-Test
# Example PROD: https://yourorg.sharepoint.com/sites/Apps
VITE_SP_SITE_URL=https://yourorg.sharepoint.com/sites/YourSite

# Internal SharePoint list name (create this list before deploying)
VITE_SP_LIST_NAME=YourListName

# Power Platform connector logical name — identical in all environments
VITE_SP_CONNECTOR_ID=shared_sharepointonline

# Connection reference ID from the target Power Platform environment
# How to find: make.powerapps.com → Connections → SharePoint Online
#              click the connection → last GUID segment in the URL
# Or run: pac connection list
VITE_SP_CONNECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Dataverse connection (fill if BACKEND_TYPE=dataverse) ─────────────────────
# Logical table name (lowercase with publisher prefix, e.g. cr123_mytable)
VITE_DV_TABLE_NAME=

# Dataverse connector logical name — identical in all environments
VITE_DV_CONNECTOR_ID=shared_commondataserviceforapps

# Connection reference ID
VITE_DV_CONNECTION_ID=

# ── App display ───────────────────────────────────────────────────────────────
# Short environment badge shown in the header (DEV | TEST | UAT | PROD)
VITE_APP_ENV_LABEL=DEV

# App / organisation name shown in the header
VITE_APP_DISPLAY_NAME={{APP_DISPLAY_NAME}}
